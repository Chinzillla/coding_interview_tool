generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String      @id @default(cuid())
  email            String      @unique
  name             String
  passwordHash     String
  twoFactorSecret  String?
  twoFactorEnabled Boolean     @default(false)
  createdAt        DateTime    @default(now())
  sessions         Session[]
  progress         Progress[]
  attempts         Attempt[]
  studyTasks       StudyTask[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Problem {
  id                 String      @id @default(cuid())
  slug               String      @unique
  title              String
  week               Int
  weekOrder          Int
  difficulty         String
  minutes            Int
  pattern            String
  dataStructure      String
  memoryPrompt       String
  memoryCorrect      String
  memoryDistractors  String
  codeStarter        String
  codeSolution       String
  explanation        String
  timeComplexity     String
  spaceComplexity    String
  runtimeDistractors String
  spaceDistractors   String
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  progress           Progress[]
  attempts           Attempt[]
  studyTasks         StudyTask[]

  @@index([week])
  @@index([pattern])
  @@index([dataStructure])
  @@index([difficulty])
}

model Progress {
  id             String    @id @default(cuid())
  userId         String
  problemId      String
  memoryScore    Int       @default(0)
  codeScore      Int       @default(0)
  runtimeScore   Int       @default(0)
  memoryDueAt    DateTime?
  codeDueAt      DateTime?
  runtimeDueAt   DateTime?
  memoryStreak   Int       @default(0)
  codeStreak     Int       @default(0)
  runtimeStreak  Int       @default(0)
  mistakeTags    String    @default("[]")
  attempts       Int       @default(0)
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem        Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@index([userId])
  @@index([problemId])
  @@index([memoryDueAt])
  @@index([codeDueAt])
  @@index([runtimeDueAt])
}

model Attempt {
  id             String   @id @default(cuid())
  userId         String
  problemId      String?
  mode           String
  memoryCorrect  Boolean?
  codeCorrect    Boolean?
  runtimeCorrect Boolean?
  score          Int
  total          Int
  answers        String
  mistakeTags    String   @default("[]")
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem        Problem? @relation(fields: [problemId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([problemId])
  @@index([mode])
}

model StudyTask {
  id             String    @id @default(cuid())
  userId         String
  problemId      String?
  key            String
  type           String
  status         String    @default("pending")
  source         String    @default("planned")
  domain         String?
  scheduledFor   DateTime
  originalFor    DateTime
  minutes        Int
  carryoverCount Int       @default(0)
  completedAt    DateTime?
  skippedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem        Problem?  @relation(fields: [problemId], references: [id], onDelete: SetNull)

  @@unique([userId, key])
  @@index([userId])
  @@index([problemId])
  @@index([scheduledFor])
  @@index([status])
  @@index([type])
}
