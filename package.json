{
  "name": "coding-interview-study-tool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:postgres": "prisma generate --schema prisma/schema.postgres.prisma && next dev",
    "build": "prisma generate && next build",
    "build:postgres": "prisma generate --schema prisma/schema.postgres.prisma && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:push": "prisma db push || node prisma/init-sqlite.js",
    "db:push:postgres": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:seed": "node prisma/seed.js",
    "db:reset": "node prisma/init-sqlite.js --reset && node prisma/seed.js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@prisma/client": "^6.16.1",
    "@uiw/react-codemirror": "^4.25.10",
    "bcryptjs": "^3.0.2",
    "lucide-react": "^0.544.0",
    "next": "^15.5.4",
    "postcss": "8.5.10",
    "prisma": "^6.16.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
